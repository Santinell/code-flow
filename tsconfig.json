{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "outDir": "./dist",
    "rootDir": "./",
    "paths": {
      "#src/*": ["./src/*"],
      "#config/*": ["./src/config/*"],
      "#db/*": ["./src/db/*"],
      "#evals/*": ["./src/evals/*"],
      "#integrations/*": ["./src/integrations/*"],
      "#mastra/*": ["./src/mastra/*"],
      "#utils/*": ["./src/utils/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.json"],
  "exclude": ["node_modules", "dist"]
}
