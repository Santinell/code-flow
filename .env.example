# Environment Configuration
# Copy to .env and fill in your values

# ── Telegram (Architect Bot) ─────────────
TELEGRAM_BOT_TOKEN=

# ── Git / Target Project ─────────────────
PROJECT_PATH=/path/to/your/project
WORKTREE_PATH=/path/to/your/worktree
GIT_MAIN_BRANCH=main
GIT_REMOTE=origin
GIT_AUTHOR_NAME=DevAgent
GIT_AUTHOR_EMAIL=agent@dev.local

# ── Workflow Config ──────────────────────
POLL_INTERVAL_MS=30000           # How often to poll Linear for tasks
MAX_CLARIFICATION_ROUNDS=5       # Max back-and-forth for Architect
MAX_CONCURRENT_DEVELOPER_TASKS=1 # Max developer workflows running simultaneously
MAX_CONCURRENT_REVIEWER_TASKS=1  # Max reviewer workflows running simultaneously

MAX_CONCURRENT_EVAL=2             # Parallel eval items; try 2-3 if provider limits allow

# Extra binaries allowed in agent-derived install/test commands for unknown
# stacks. Supplements the built-in allowlist; cannot remove
# builtin entries (pnpm/uv/cargo/...). Comma- or space-separated. Optional.
# ALLOWED_BINARIES=dvc,just,turbine

# ── Agent Step Budgets ────────────────────
MAX_STEPS_ANALYZE=15             # Steps for codebase analysis phase
MAX_STEPS_IMPLEMENT=20           # Steps for implementation phase
MAX_STEPS_FIX=15                 # Steps for test-fix phase
MAX_STEPS_AGENT_DEVELOPER=6      # Max steps for developer agent (min 3)
MAX_STEPS_AGENT_REVIEWER=5       # Max steps for reviewer agent (min 3)
MAX_STEPS_AGENT_ARCHITECT=10     # Max steps for architect agent (min 5)
MAX_OUTPUT_TOKENS_DEVELOPER=4096  # Output token budget for developer agent
MAX_OUTPUT_TOKENS_REVIEWER=4096   # Output token budget for reviewer agent
MAX_OUTPUT_TOKENS_ARCHITECT=8192  # Output token budget for architect agent

EMBEDDING_MEMORY=false

# ── Database ──────────────────────────────
DB_PATH=./data/agent-dev.db    # SQLite database path

# ── Logging ──────────────────────────────
LOG_LEVEL=info
