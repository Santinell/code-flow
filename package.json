{
  "name": "code-flow",
  "version": "0.1.0",
  "description": "Automated agentic development system built on Mastra framework",
  "type": "module",
  "imports": {
    "#src/*": [
      "./dist/*.js",
      "./src/*.ts"
    ],
    "#config/*": [
      "./dist/config/*.js",
      "./src/config/*.ts"
    ],
    "#db/*": [
      "./dist/db/*.js",
      "./src/db/*.ts"
    ],
    "#evals/*": [
      "./dist/evals/*.js",
      "./src/evals/*.ts"
    ],
    "#integrations/*": [
      "./dist/integrations/*.js",
      "./src/integrations/*.ts"
    ],
    "#mastra/*": [
      "./dist/mastra/*.js",
      "./src/mastra/*.ts"
    ],
    "#utils/*": [
      "./dist/utils/*.js",
      "./src/utils/*.ts"
    ]
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "start:prod": "node dist/index.js",
    "build": "tsc && swc src --copy-files --strip-leading-paths --out-dir ./dist",
    "check": "tsc && pnpm lint && pnpm format:check",
    "trigger:architect": "tsx src/triggers/telegram-webhook.ts",
    "trigger:poller": "tsx src/triggers/ticket-poller.ts",
    "eval:architect": "tsx src/evals/experiments/agent-evals.ts --agent=architect",
    "eval:developer": "tsx src/evals/experiments/agent-evals.ts --agent=developer",
    "eval:reviewer": "tsx src/evals/experiments/agent-evals.ts --agent=reviewer",
    "eval:workflows": "tsx src/evals/experiments/workflow-evals.ts",
    "eval:ci": "tsx src/evals/experiments/agent-evals.ts --ci",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.85",
    "@ai-sdk/deepseek": "^2.0.39",
    "@ai-sdk/openai": "^3.0.73",
    "@ai-sdk/provider": "^3.0.10",
    "@linear/sdk": "^86.0.0",
    "@mastra/core": "^1.45.0",
    "@mastra/evals": "^1.4.0",
    "@mastra/libsql": "^1.14.0",
    "@mastra/memory": "^1.21.0",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "execa": "^9.6.1",
    "fast-glob": "^3.3.3",
    "grammy": "^1.44.0",
    "ollama-ai-provider-v2": "^3.6.0",
    "pino": "^10.3.1",
    "simple-git": "^3.36.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.0",
    "@vitest/runner": "^4.1.9",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.9"
  }
}