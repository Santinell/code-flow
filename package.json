{
  "name": "code-flow",
  "version": "0.1.0",
  "description": "Automated agentic development system built on Mastra framework",
  "type": "module",
  "scripts": {
    "start": "tsx src/orchestrator.ts",
    "build": "tsc",
    "check": "tsc --noEmit && pnpm lint && pnpm format:check",
    "trigger:architect": "tsx src/triggers/telegram-webhook.ts",
    "trigger:poller": "tsx src/triggers/linear-poller.ts",
    "trigger:scheduler": "tsx src/triggers/scheduler.ts",
    "eval:architect": "tsx src/mastra/evals/experiments/agent-evals.ts --agent=architect",
    "eval:developer": "tsx src/mastra/evals/experiments/agent-evals.ts --agent=developer",
    "eval:reviewer": "tsx src/mastra/evals/experiments/agent-evals.ts --agent=reviewer",
    "eval:workflows": "tsx src/mastra/evals/experiments/workflow-evals.ts",
    "eval:ci": "tsx src/mastra/evals/experiments/agent-evals.ts --ci",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.85",
    "@ai-sdk/deepseek": "^2.0.39",
    "@ai-sdk/openai": "^3.0.73",
    "@ai-sdk/provider": "^3.0.10",
    "@linear/sdk": "^86.0.0",
    "@mastra/core": "^1.45.0",
    "@mastra/evals": "^1.4.0",
    "@mastra/libsql": "^1.14.0",
    "@mastra/memory": "^1.21.0",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "execa": "^9.6.1",
    "fast-glob": "^3.3.3",
    "grammy": "^1.44.0",
    "node-cron": "^4.5.0",
    "ollama-ai-provider-v2": "^3.6.0",
    "pino": "^10.3.1",
    "simple-git": "^3.36.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.0",
    "@types/node-cron": "^3.0.11",
    "@vitest/runner": "^4.1.9",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}