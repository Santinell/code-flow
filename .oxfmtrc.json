{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "sortPackageJson": false,
  "sortImports": {
    "customGroups": [
      {
        "groupName": "hash",
        "elementNamePattern": ["#*/**"]
      }
    ],
    "groups": [["type"], ["external"], ["builtin"], ["hash"], ["parent", "sibling"], "index"],
    "sortSideEffects": true,
    "newlinesBetween": false
  },
  "semi": true,
  "trailingComma": "es5",
  "singleQuote": true,
  "bracketSpacing": true,
  "tabWidth": 2,
  "printWidth": 100,
  "endOfLine": "lf"
}
