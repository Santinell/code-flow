@@ -0,0 +1,20 @@
+import { Router } from 'express';
+
+export const usersRouter = Router();
+
+export interface UsersPage {
+  items: Array<{ id: string; name: string; email: string }>;
+  page: number;
+  totalPages: number;
+}
+
+export async function listUsers(page: number): Promise<UsersPage> {
+  const items = await db.user.findMany({ skip: (page - 1) * 20, take: 20 });
+  const total = await db.user.count();
+  return { items, page, totalPages: Math.ceil(total / 20) };
+}
+
+usersRouter.get('/', async (req, res) => {
+  const page = Number(req.query.page ?? 1);
+  res.json(await listUsers(page));
+});
