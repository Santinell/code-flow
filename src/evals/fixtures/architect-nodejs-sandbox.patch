@@ -0,0 +1,19 @@
+export type TaskStatus = 'todo' | 'in_progress' | 'done';
+
+export interface Task {
+  id: string;
+  title: string;
+  status: TaskStatus;
+}
+
+export interface TaskStatusChange {
+  task: Task;
+  previousStatus: TaskStatus;
+}
+
+export async function updateTaskStatus(taskId: string, status: TaskStatus): Promise<TaskStatusChange> {
+  const existing = await db.task.findUnique({ where: { id: taskId } });
+  const previousStatus = existing.status;
+  const task = await db.task.update({ where: { id: taskId }, data: { status } });
+  return { task, previousStatus };
+}
