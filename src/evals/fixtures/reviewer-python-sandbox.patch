--- /dev/null
+++ b/src/auth/password.py
@@ -0,0 +1,11 @@
+import re
+
+
+def validate_password(password: str) -> bool:
+    if len(password) < 12:
+        return False
+    if not re.search(r"[A-Z]", password):
+        return False
+    if not re.search(r"[0-9]", password):
+        return False
+    return True
