+++ b/src/utils/format.py
@@ -0,0 +1,5 @@
+def format_display_name(first_name: str, last_name: str) -> str:
+    first = first_name.strip()
+    last = last_name.strip()
+    parts = [p for p in [first, last] if p]
+    return " ".join(parts)
