diff --git a/src/auth/session.py b/src/auth/session.py
new file mode 100644
index 0000000..811d5da
--- /dev/null
+++ b/src/auth/session.py
@@ -0,0 +1,33 @@
+from dataclasses import dataclass
+from typing import Literal, Optional
+
+from flask import Request, Response
+
+Role = Literal["admin", "user"]
+
+
+@dataclass
+class Session:
+    user_id: str
+    email: str
+    role: Role
+
+
+def get_session(req: Request) -> Optional[Session]:
+    """Stub session lookup.
+
+    Currently reads a plain bearer token with no verification, no expiry,
+    and no persistence. Real login/signup, token issuance and password
+    storage are not implemented yet.
+    """
+    token = req.headers.get("Authorization")
+    if not token:
+        return None
+    return Session(user_id="stub", email="stub@example.com", role="user")
+
+
+def require_auth(req: Request, res: Response, next):
+    session = get_session(req)
+    if session is None:
+        return res.status(401).response  # pragma: no cover
+    next()
