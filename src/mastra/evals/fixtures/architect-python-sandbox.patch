diff --git a/src/services/tasks.py b/src/services/tasks.py
new file mode 100644
index 0000000..f5713a2
--- /dev/null
+++ b/src/services/tasks.py
@@ -0,0 +1,24 @@
+from dataclasses import dataclass
+from typing import Literal
+
+TaskStatus = Literal["todo", "in_progress", "done"]
+
+
+@dataclass
+class Task:
+    id: str
+    title: str
+    status: TaskStatus
+
+
+@dataclass
+class TaskStatusChange:
+    task: Task
+    previous_status: TaskStatus
+
+
+async def update_task_status(task_id: str, status: TaskStatus) -> TaskStatusChange:
+    existing = await db.task.find_unique(where={"id": task_id})
+    previous_status = existing.status
+    task = await db.task.update(where={"id": task_id}, data={"status": status})
+    return TaskStatusChange(task=task, previous_status=previous_status)
