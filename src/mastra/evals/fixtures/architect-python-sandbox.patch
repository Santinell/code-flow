diff --git a/src/routes/users.py b/src/routes/users.py
new file mode 100644
index 0000000..08000e8
--- /dev/null
+++ b/src/routes/users.py
@@ -0,0 +1,22 @@
+from flask import Blueprint, jsonify, request
+
+users_bp = Blueprint("users", __name__)
+
+
+class UserPage:
+    def __init__(self, items, page, total_pages):
+        self.items = items
+        self.page = page
+        self.total_pages = total_pages
+
+
+async def list_users(page: int) -> UserPage:
+    items = await db.user.find_many(skip=(page - 1) * 20, take=20)
+    total = await db.user.count()
+    return UserPage(items=items, page=page, total_pages=(total + 19) // 20)
+
+
+@users_bp.get("/")
+async def get_users():
+    page = int(request.args.get("page", 1))
+    return jsonify(await list_users(page))
